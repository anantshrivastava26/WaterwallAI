# Application
APP_ENV=development
LOG_LEVEL=INFO

# Storage
SQLITE_PATH=./data/waterwall.sqlite

# LM Studio (OpenAI-compatible endpoint)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=gemma-4-e4b-uncensored-hauhaucs-aggressive

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=waterwall_messages

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password

# AI Budget (section 11)
DAILY_LLM_TOKEN_BUDGET=50000
MAX_CONTEXT_MESSAGES=25
SUMMARY_BATCH_SIZE=50
LLM_PRIORITY_THRESHOLD=0.7
